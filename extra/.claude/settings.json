{
  "env": {
    "EDITOR": "hx",
    "VISUAL": "hx"
  },
  "permissions": {
    "allow": [
      "Bash(jj log *)",
      "Bash(jj st *)",
      "Bash(jj diff *)",
      "Bash(jj desc *)",
      "Bash(jj show *)",
      "Bash(jj new *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go fmt *)",
      "Bash(go vet *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(chmod *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(jj git *)",
      "Bash(jj commit *)",
      "Bash(jj bookmark *)",
      "Bash(jj git push *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm remove *)",
      "Bash(pnpm install *)",
      "Bash(pnpm uninstall *)",
      "Bash(pnpm remove *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(poetry add *)",
      "Bash(poetry remove *)",
      "Bash(terraform apply *)",

      "Read(.env)",
      "Read(.env*)",
      "Read(**/.env)",
      "Read(**/.env.keys)",
      "Read(id_rsa*)",
      "Read(id_ed25519*)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(utils.nu)",
      "Read(**/*secrets*)",
      "Read(**/credentials*)",

      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(**/credentials*)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": ["/tmp", "."],
      "denyWrite": ["/etc"],
      "denyRead": ["~/.aws", "~/.config/gcloud"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com"
      ],
      "allowLocalBinding": true
    }
  },
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
